# ── DevSearch environment variables ───────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Endee Vector Database ─────────────────────────────
# Default: http://localhost:8080/api/v1
ENDEE_BASE_URL=http://localhost:8080/api/v1

# Optional — leave blank for open mode, or set a token
ENDEE_AUTH_TOKEN=

# ── DevSearch API ─────────────────────────────────────
# URL of the FastAPI backend (used by Streamlit frontend)
DEVSEARCH_API_URL=http://localhost:8000

# ── OpenRouter (for RAG / Ask feature) ────────────────
# Get a free key at https://openrouter.ai
OPENROUTER_API_KEY=

# Model to use (default: Gemini Flash 1.5)
OPENROUTER_MODEL=google/gemini-flash-1.5

# ── GitHub ────────────────────────────────────────────
# Optional — raises API rate limit from 60 → 5,000 req/hr
GITHUB_TOKEN=
