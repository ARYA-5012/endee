# ─── Endee Vector Database ───────────────────────────────────────────────────
# URL of your running Endee server
ENDEE_BASE_URL=http://localhost:8080/api/v1

# Optional: set if you started Endee with NDD_AUTH_TOKEN
ENDEE_AUTH_TOKEN=

# ─── OpenRouter (LLM for RAG Q&A) ────────────────────────────────────────────
# Get your free key at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use (default: Gemini Flash — fast & free tier)
OPENROUTER_MODEL=google/gemini-flash-1.5

# ─── GitHub (optional but recommended) ───────────────────────────────────────
# A GitHub personal access token increases rate limits from 60 to 5000 req/hr
# Generate at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_TOKEN=
